prefix=${pcfiledir}/..
includedir=${prefix}/include
libdir=${prefix}/lib-x86_64-linux

Name: libghostty-vt-static
URL: https://github.com/ghostty-org/ghostty
Description: Ghostty VT library (static, cross-built for x86_64-linux)
Version: 0.1.0-dev
Cflags: -I${includedir}
Libs: ${libdir}/libghostty-vt.a
