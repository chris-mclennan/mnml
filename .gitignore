# libghostty-vt prebuilts — the .a / .so / .dylib files are too
# big to ship in git (37MB across 3 targets). They live on a
# GitHub release; fetch with vendor/libghostty-vt/fetch-prebuilts.sh
# (idempotent — CI + local devs run it once before cargo build).
/vendor/libghostty-vt/**/*.a
/vendor/libghostty-vt/**/*.dylib
/vendor/libghostty-vt/**/*.so
/vendor/libghostty-vt/**/*.so.*
/vendor/libghostty-vt/out/
