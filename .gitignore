# libghostty-vt prebuilts — static .a files for each supported
# platform are tracked so CI can link without a Zig toolchain.
# (macOS-arm64: 8MB, x86_64-linux: 14MB — small enough to skip
# git-lfs.) Dynamic .dylib / .so are gitignored — only for local
# dev / dynamic linking experiments. Regenerate via
# vendor/libghostty-vt/build-*.sh + the README.md instructions.
/vendor/libghostty-vt/**/*.dylib
/vendor/libghostty-vt/**/*.so
/vendor/libghostty-vt/**/*.so.*
/vendor/libghostty-vt/out/
