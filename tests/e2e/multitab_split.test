# 2026-06-22 — multi-tab split semantics. Opening a second file
# in a split should ADD it as a tab (not replace), and closing a
# tab in a split should fall back to a sibling instead of
# collapsing the leaf unless it was the last tab.

write a.txt "alpha file"
write b.txt "beta file"
write c.txt "charlie file"

open a.txt
expect pane "a.txt"

# Split right — both halves currently show a.txt (split copies
# the current file into the new half so both sides start with
# context).
command view.split_right
expect pane "a.txt"

# Open b.txt — under multi-tab semantics, this ADDS b.txt as a
# new tab in the FOCUSED leaf (the right side after the split),
# making b.txt the active tab there.
open b.txt
expect pane "b.txt"

# Open c.txt — same leaf, third tab. Active is now c.txt.
open c.txt
expect pane "c.txt"

# Close the active pane → falls back to a sibling tab in the
# same leaf (rightward neighbour preferred, else leftward).
# After closing c.txt, b.txt or a.txt should remain active.
# `ex bd` is input-style-agnostic (works in both vim + standard);
# `key ctrl+w` was interfering as a vim leader prefix.
ex bd
# After close, the leaf still exists with the remaining tabs.
expect screen lacks "c.txt"
