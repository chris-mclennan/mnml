# node_modules should be hidden when listed in .gitignore.
# Tests the gitignore-aware tree for TypeScript workspace shape.

shell mkdir -p node_modules/.bin
shell echo "fake-dep" > node_modules/fake-dep.js
shell echo "node_modules/" > .gitignore
shell echo '{"name":"app"}' > package.json
shell mkdir -p src
shell echo "console.log('hello')" > src/index.ts

# The tree enumerated the (empty) temp workspace at startup, before the
# `shell` commands above created these files — refresh so it re-scans.
command tree.refresh
open src/index.ts
expect screen contains "src"
expect screen lacks "node_modules"
