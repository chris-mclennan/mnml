# Right-click on a file-tree row opens its context menu; Esc dismisses.
write notes.txt hello
open notes.txt
# The fixture is written after App::new scanned the workspace — refresh
# so the tree actually shows notes.txt.
command tree.refresh

# Rail: palette bar row 0, bufferline row 1, workspace header
# row 2, notes.txt file row 3. Right-click the file row.
rightclick 4 3
expect screen contains "Copy path"
key esc
expect screen lacks "Copy path"
expect pane "notes.txt"
