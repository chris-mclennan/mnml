# Regression: the file tree HIDES node_modules even without a .gitignore.
#
# History: 2026-06-28 3rd multilang-dev-user pass found the tree
# surfaced node_modules whenever no .gitignore was committed — while
# the file picker (Ctrl+P) already hardcoded a node_modules exclusion.
# A TS dev running `npm install` on a project that hadn't committed
# .gitignore would see node_modules flood the rail. Fixed 2026-06-28
# by adding the same hardcoded exclusion list to src/tree.rs.

shell mkdir -p node_modules/some-dep
shell echo '{}' > node_modules/some-dep/index.js
shell echo '{"name":"test","version":"1.0.0"}' > package.json
shell mkdir -p src
shell echo 'console.log("hi")' > src/index.ts

command tree.refresh
wait 100

# node_modules must NOT be visible in the tree (hardcoded exclusion),
# even without a .gitignore.
expect screen lacks "node_modules"
# The real source dir IS visible.
expect screen contains "src"
