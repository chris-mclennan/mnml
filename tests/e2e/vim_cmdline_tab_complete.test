# `:` cmdline Tab completion — cycles through ex commands AND registered
# palette commands. 2026-06-19 — completer was unified (registry + vim
# ex names merged); first Tab now picks the highest-scoring alphabetical
# match across both sources.

write data.txt "alpha"
open data.txt
command editor.use_vim

# Open the cmdline. Type "wr" — Tab cycles. Multiple matches now exist:
# - ai.write_branch_name (id-contains "wr", score 200)
# - ai.write_tests (id-contains "wr", score 200)
# - view.toggle_wrap (id-contains "wr", score 200)
# - write (EX prefix, score 150)
# First Tab picks the alphabetically-first at the highest score tier
# (`ai.write_branch_name` sorts before `ai.write_tests`).
key :
type "wr"
key tab
expect screen contains ":ai.write_branch_name"
key escape

# "ta" has many matches. tab.* commands (id-prefix, score 300) outrank
# tabclose etc. (EX prefix, score 150). First Tab picks tab.close
# (alphabetically first at 300).
key :
type "ta"
key tab
expect screen contains ":tab.close"
key tab
expect screen contains ":tab.first"
key escape

# File-path completion: after a path-accepting command + space, Tab cycles
# through workspace entries. Set up a few files so we have something to
# complete.
write apple.md "a"
write apricot.md "b"

key :
type "e ap"
key tab
# First match (alphabetical): "apple.md".
expect screen contains ":e apple.md"
# Second Tab → "apricot.md".
key tab
expect screen contains ":e apricot.md"
key escape
