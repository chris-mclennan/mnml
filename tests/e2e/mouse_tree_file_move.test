# Drag a file onto a folder in the tree → confirm prompt → file moves.
# Guards the tree-drag MOVE path (which shares the restructured tree-drag
# release with the new tree drag-to-split).
write sub/cc.txt cc-content
write aa.txt aa-content
open aa.txt
command tree.refresh

# After tree.refresh, ac96648 auto-expands top-level dirs. Rail
# after adding the palette bar (row 0) + bufferline (row 1):
# workspace header row 2, sub/ (open) row 3, cc.txt row 4,
# aa.txt row 5. Drag aa.txt (row 5) up onto sub/ (row 3).
drag 7 5 7 3
expect screen contains "Move to"
key enter
expect file sub/aa.txt contains "aa-content"
