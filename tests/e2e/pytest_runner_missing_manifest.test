# pytest runners from a workspace with no pyproject.toml, setup.py,
# requirements.txt, or test files.
# Should toast "pytest: no pyproject.toml / setup.py / requirements.txt / test files at ..."

command pytest.run
wait 50
expect screen contains "pytest: no pyproject.toml"

key esc

command pytest.failed
wait 50
expect screen contains "pytest: no pyproject.toml"
