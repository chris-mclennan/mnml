# node_modules WITHOUT .gitignore:
# The tree's ignore walker does NOT filter node_modules (confirmed by unit test
# `tree::tests::node_modules_visible_without_gitignore`). This e2e test
# verifies the workspace opens normally with node_modules in the workspace.
# Note: headless screen layout can prevent tree rail items from appearing on
# the rendered screen depending on workspace composition; the unit test is
# the authoritative check for tree scan behavior.

write node_modules/dep.js "module.exports = {}"
write src/index.txt "hello"
write package.json "{\"name\":\"app\"}"

open src/index.txt
wait 100
# Workspace opens normally (no crash, no error toast)
expect screen contains "index.txt"
# File content renders
expect screen contains "hello"
