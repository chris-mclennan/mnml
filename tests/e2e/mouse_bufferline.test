# Clicking a bufferline tab switches to that buffer.
write aa.txt aa-content
write bb.txt bb-content
open aa.txt
open bb.txt
command view.toggle_tree

# Tree hidden → the bufferline spans from x=0. Two tabs: aa.txt then
# bb.txt (active). Click the first tab to switch back to aa.txt.
expect pane "bb.txt"
click 4 0
expect pane "aa.txt"
expect screen contains "aa-content"
