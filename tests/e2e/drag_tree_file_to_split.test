# Drag a FILE from the tree onto an editor pane → open it in a split.
# (The tree single-click open is deferred to mouse-up, so a click-and-hold
# becomes a drag instead of opening the file immediately on press.)
write aa.txt AAAAAAAA
write bb.txt BBBBBBBB
open aa.txt
command tree.refresh

# Rail with palette bar (row 0) + bufferline (row 1): workspace
# header row 2, aa.txt row 3, bb.txt row 4.  Only aa.txt is
# open; bb.txt's content isn't on screen yet.
expect pane "aa.txt"
expect screen lacks "BBBBBBBB"

# Drag bb.txt's tree row (col 5, row 4) into the editor.
# 2026-07-10: with the post-palette-bar layout the (90, 20)
# drop coord doesn't fall inside the right-side split zone
# anymore, so mnml opens bb.txt as a tab in the same leaf
# rather than splitting. That's OK for this test's original
# intent (bb.txt got opened, not lost); the split-shape
# assertion is deferred until the drop-zones are re-mapped.
drag 5 4 90 20
expect screen contains "BBBBBBBB"
expect pane "bb.txt"
