# A left-click on a file row in the tree opens that file.
write aa.txt content-of-aa
write bb.txt content-of-bb
open aa.txt
command tree.refresh

# Rail after refresh: with the palette bar on screen row 0 +
# bufferline on row 1, the tree's workspace header lands on
# row 2. Files: aa.txt on row 3, bb.txt on row 4. Click bb.txt.
expect pane "aa.txt"
click 5 4
expect pane "bb.txt"
expect screen contains "content-of-bb"
