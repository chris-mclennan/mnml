# AI ghost-text (Cursor-style inline suggestion) accept + dismiss flow.
# The real suggestion comes from a worker thread (Claude API / local
# model) which can't run deterministically in a test, so the `ghost`
# step injects the suggestion state directly — what's under test here is
# the key handling: bare Tab accepts, any other key dismisses.
write a.txt hello
open a.txt

# Inject a suggestion — the ghost overlay paints it at the cursor.
ghost GHOSTX
expect screen contains "GHOSTX"

# Bare Tab accepts it — the text lands in the buffer (cursor is at
# byte 0, so it goes in front of "hello") and the buffer is now dirty.
key tab
expect screen contains "GHOSTX"
expect dirty true

# Save, then confirm the accepted text actually hit disk.
key ctrl+s
expect dirty false
expect file a.txt contains "GHOSTXhello"

# Dismiss flow — inject a fresh suggestion, then press a non-Tab key.
# The ghost is cleared and never enters the buffer.
ghost DISMISSZ
expect screen contains "DISMISSZ"
key right
expect screen lacks "DISMISSZ"
expect dirty false

# Partial accept — Ctrl+Right takes one word at a time, the remainder
# stays as a ghost. A fresh buffer keeps the cursor at byte 0.
write b.txt seed
open b.txt
ghost "ALPHA BETA"
expect screen contains "ALPHA BETA"
key ctrl+right
expect dirty true
key ctrl+right
key ctrl+s
expect file b.txt contains "ALPHA BETAseed"

# Partial accept — Ctrl+Down takes the next line (through the newline);
# the line below stays as a ghost until Tab finishes it.
write c.txt tail
open c.txt
ghost "LINE1\nLINE2"
expect screen contains "LINE1"
key ctrl+down
expect dirty true
key tab
key ctrl+s
expect file c.txt contains "LINE1\nLINE2tail"
