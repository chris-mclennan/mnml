# Find + Replace: type a query, accept; then run replace, type the replacement,
# accept; toast reports the count and the buffer reflects the change.
write notes.txt "alpha beta alpha gamma alpha"
open notes.txt

# Set up the find state — Ctrl+F → "alpha" → Enter.
command find.find
type alpha
key enter
expect screen contains "match 1/3"

# Now `find.replace` (Ctrl+H) prompts, but only because there's a non-empty find.
command find.replace
expect screen contains "Replace 3"
type DELTA
key enter

# Toast says how many were replaced, and the buffer shows the swap.
expect screen contains "replaced 3"
expect screen contains "DELTA beta DELTA gamma DELTA"
expect dirty true
