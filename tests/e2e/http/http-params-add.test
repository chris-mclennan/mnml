# http.params_add opens an inline `(name)` / `(value)` draft row
# on the Params tab. Tab moves from name → value; Enter commits.

write anchor.txt anchor
open anchor.txt

command http.new

type "https://example.com/api"

command http.params_add

# Draft row starts with caret in the key cell (rendered as "▏")
# and "(value)" placeholder in the value cell. Also auto-switches
# to the Params tab.
expect screen contains "(value)"
expect screen contains "Params"

# Type the key, Tab into the value cell, type the value, Enter to commit.
type "userid"
key tab
type "42"
key enter

expect screen contains "userid=42"
