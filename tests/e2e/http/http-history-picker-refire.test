# http.history opens a fuzzy picker over .rqst/history.jsonl (newest
# first) and Enter on a row opens it as a scratch .curl buffer.

write .rqst/history.jsonl "{\"ts\":1000,\"method\":\"POST\",\"url\":\"https://api.example.com/login\",\"status\":200,\"duration_ms\":88,\"body_bytes\":64,\"error\":null}\n{\"ts\":2000,\"method\":\"GET\",\"url\":\"https://api.example.com/users\",\"status\":200,\"duration_ms\":42,\"body_bytes\":512,\"error\":null}"

write anchor.txt anchor
open anchor.txt

command http.history

expect screen contains "HTTP history"
expect screen contains "api.example.com/users"
expect screen contains "api.example.com/login"

key enter

expect screen contains "api.example.com/users"
expect pane "[scratch]"
