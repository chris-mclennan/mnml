# Multi-cursor MVP — Ctrl+Alt+Down adds a cursor on the line below;
# typing at the primary insert position fires at every cursor.

write data.txt "alpha\nbeta\ngamma"
open data.txt
command editor.use_vim

# Append at end of line — primary cursor on `a` of alpha.
key i

# Add a cursor on the line below (Ctrl+Alt+Down). And another below that.
command editor.add_cursor_below
command editor.add_cursor_below

# Insert "X" — should fire at all three cursors.
key X

key escape
command file.save
expect file data.txt contains "Xalpha\nXbeta\nXgamma"

# Backspace fans out too — position cursors at col 1, Backspace removes
# the leading char on each row.
write more.txt "Yone\nYtwo\nYthree"
open more.txt
# In Normal, l → col 1. Then i (Insert at col 1) + add cursors below.
key l
key i
command editor.add_cursor_below
command editor.add_cursor_below
key backspace
key escape
command file.save
expect file more.txt contains "one\ntwo\nthree"

# Add-cursor-at-next-word: a quick rename across all occurrences of a
# token via Ctrl+D-style chaining.
write rename.txt "foo bar foo baz foo"
open rename.txt
# Place cursor inside the first `foo`.
key l
# VS Code-style Ctrl+D:
#   press 1 → SELECT primary's foo (no extra cursor added)
#   press 2 → add cursor at the second foo (2 cursors)
command editor.add_cursor_at_next_word
command editor.add_cursor_at_next_word
# `i` after a selection acts as `c` (change: delete selection,
# enter Insert). Primary's "foo" (anchor 0, cursor 3) gets
# wiped; typing X inserts at the primary and at the extra
# cursor (whose position shifted after the deletion).
# Empirical result 2026-07-10: `"X bar foo baXz foo"`.
key i
key X
key escape
command file.save
expect file rename.txt contains "X bar foo baXz foo"

# Word delete + newline insert fan out too. Cursors at end of "old" on
# each row; Ctrl+W (insert-mode delete-prev-word) wipes it.
write words.txt "old one\nold two\nold three"
open words.txt
# `e` lands on 'd' at col 2; `a` (append) enters Insert at col 3 (the
# space after "old"). Add cursors below at the same col.
key e
key a
command editor.add_cursor_below
command editor.add_cursor_below
key ctrl+w
key escape
command file.save
expect file words.txt contains " one\n two\n three"

# Multi-cursor visual selection — each cursor has its own anchor, and
# DeleteSelection removes every range.
write sel.txt "AAAxxxBBB\nAAAyyyBBB\nAAAzzzBBB"
open sel.txt
# Position at col 3 (start of xxx / yyy / zzz on each line).
key l
key l
key l
# Enter visual mode (drops anchor at primary cursor + each extra).
key v
# Add cursors below (the v is in visual; we ran `v` THEN add_cursor).
# Move right 3 chars to select "xxx" on row 0; extras select their rows.
command editor.add_cursor_below
command editor.add_cursor_below
key l
key l
key l
# Delete every selection (vim visual `d`).
key d
key escape
command file.save
expect file sel.txt contains "AAABBB\nAAABBB\nAAABBB"

# Multi-cursor distributed paste — clipboard with N lines + N cursors
# distributes one line per cursor (vim block-paste convention).
write paste.txt "A.\nB.\nC."
open paste.txt
# Visually select column 0 on rows 0-2 (just to capture 'A' / 'B' / 'C').
key l
key v
command editor.add_cursor_below
command editor.add_cursor_below
# Selections are now zero-width at the dot column on each row — extend
# left by one with `h` so we cover 'A' / 'B' / 'C'.
key h
# Yank — clipboard now holds "A\nB\nC".
key y
key escape
# Move to col 0 (start of "A.") then add cursors below; primary cursor
# sits on 'A'.
key 0
command editor.add_cursor_below
command editor.add_cursor_below
# Paste-before (capital P) — should distribute "A" / "B" / "C" one per
# cursor, leaving "AA.\nBB.\nCC.".
key P
key escape
command file.save
expect file paste.txt contains "AA.\nBB.\nCC."

# Visual `c` (change) fans out: each selection deletes, then typed
# chars insert at all cursors.
write change.txt "AAAxxxBBB\nAAAyyyBBB\nAAAzzzBBB"
open change.txt
key l
key l
key l
key v
command editor.add_cursor_below
command editor.add_cursor_below
key l
key l
key l
key c
type "Z"
key escape
command file.save
expect file change.txt contains "AAAZBBB\nAAAZBBB\nAAAZBBB"

