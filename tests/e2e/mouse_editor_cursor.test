# Clicking in the editor body places the cursor on that line — the
# statusline Ln chip confirms where it landed.
write doc.txt "ED01\nED02\nED03\nED04\nED05\nED06\nED07\nED08\nED09\nED10\nED11\nED12\nED13\nED14\nED15\nED16\nED17\nED18\nED19\nED20"
open doc.txt
command view.toggle_tree
expect screen contains "Ln 1"

# Screen layout: row 0 palette top-bar, row 1 bufferline, rows 2..N
# editor body. So click at screen y=10 lands on file line 9
# (10 - 2 + 1 = 9).
click 40 10
expect screen contains "Ln 9"
