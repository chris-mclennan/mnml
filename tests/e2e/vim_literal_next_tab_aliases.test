# Vim insert `Ctrl+V` (literal-next) — typing the next key verbatim instead
# of going through the chord / tab-expand path. (The previous version of
# this test also exercised :tabprev / :tabnext / :tabfirst / :tablast as
# buffer-cycling aliases; those are now real vim tab pages — see
# tests/e2e/tab_pages.test. Buffer cycling moved to :bnext / :bprev.)

write data.txt "hello"
open data.txt
command editor.use_vim

# Append at end of line, then Ctrl+V Tab to insert a literal tab.
key A
key ctrl+v
key tab
key escape
command file.save
expect file data.txt contains "hello\t"

# Buffer cycling via :bnext / :bprev across two open buffers.
write more.txt "world"
open more.txt
# Now active is more.txt. :bprev ⇒ data.txt
key :
type "bprev"
key enter
expect pane "data.txt"

# :bnext ⇒ more.txt
key :
type "bnext"
key enter
expect pane "more.txt"
