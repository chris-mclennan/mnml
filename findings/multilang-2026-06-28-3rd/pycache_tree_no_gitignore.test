# __pycache__ and node_modules at depth 0 appear in the file tree when
# no .gitignore suppresses them.  The file PICKER hardcodes node_modules,
# target, .next, dist, build exclusions (app/picker.rs:98) but the file
# TREE does NOT hardcode ANY directory — it relies entirely on the
# ignore crate + .gitignore.
#
# SEV-3: inconsistency between tree rail and Ctrl+P file picker.
# A Python dev who hasn't committed .gitignore sees __pycache__;
# a TS dev who ran `npm install` without .gitignore sees node_modules.
#
# Note: tree.refresh does not re-apply the startup auto-expand that
# Tree::open uses, so only depth-0 items are visible after refresh
# (children are collapsed). Depth-0 __pycache__ (rare but possible
# in Django projects) IS visible.

shell mkdir -p __pycache__
shell touch __pycache__/app.cpython-312.pyc
shell mkdir -p node_modules/dep
shell touch node_modules/dep/index.js

command tree.refresh
wait 200

# Both artifact dirs appear at the top level in the tree without .gitignore.
# The picker (Ctrl+P) would NOT show them, but the tree rail DOES.
expect screen contains "__pycache__"
expect screen contains "node_modules"
