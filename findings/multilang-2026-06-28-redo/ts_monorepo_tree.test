# TypeScript monorepo: packages/* layout visible in tree.
# Note: tree.refresh does not re-run auto-expand for newly-added dirs —
# directories created AFTER App::new() must be manually expanded.
# At a minimum, packages/ itself should appear as a row.

shell mkdir -p packages/server/src packages/client/src
shell echo '{"name":"@app/server"}' > packages/server/package.json
shell echo '{"name":"@app/client"}' > packages/client/package.json
shell echo 'export const server = 1;' > packages/server/src/server.ts
shell echo 'export const client = 1;' > packages/client/src/client.ts
shell echo '{"name":"root-monorepo"}' > package.json
shell printf 'packages:\n  - packages/*\n' > pnpm-workspace.yaml

command tree.refresh
open packages/server/src/server.ts
wait 100
# packages/ dir appears at top level
expect screen contains "packages"
# workspace-level files appear
expect screen contains "package.json"
# server.ts opens correctly
expect screen contains "server"
expect screen contains "export const server"
