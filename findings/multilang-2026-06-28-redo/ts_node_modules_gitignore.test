# node_modules hidden with .gitignore, dist/ also hidden

shell mkdir -p node_modules/lodash
shell echo "module.exports = {}" > node_modules/lodash/index.js
shell mkdir -p dist
shell echo "compiled" > dist/index.js
shell mkdir -p src
shell echo 'export const x = 1;' > src/index.ts
shell printf 'node_modules/\ndist/\n' > .gitignore

command tree.refresh
open src/index.ts
expect screen contains "src"
expect screen lacks "node_modules"
expect screen lacks "dist"
